{
    "name": "@thebcms/mcp",
    "version": "0.1.0",
    "description": "MCP server and client for BCMS",
    "author": "BCMS",
    "license": "MIT",
    "scripts": {
        "dev": "env-cmd -- nodemon --watch 'src/**/*.ts' --exec 'ts-node -r tsconfig-paths/register' src/main.ts",
        "build:ts:mjs": "tsc --project tsconfig.json",
        "build:ts:cjs": "tsc --project tsconfig.commonjs.json",
        "_test": "ts-node --project ./tsconfig.commonjs.json -r tsconfig-paths/register src/_test.ts"
    },
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "@thebcms/types": "^2.0.0",
        "@thebcms/utils": "^2.0.0",
        "axios": "^1.13.6",
        "fastify": "^5.7.4",
        "fastify-mcp-server": "^0.7.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^22.5.5",
        "env-cmd": "^11.0.0",
        "eslint": "^10.0.2",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.6.2",
        "typescript-eslint": "^8.56.1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bcms/utils"
    },
    "bugs": {
        "url": "https://github.com/bcms/utils/issues"
    },
    "homepage": "https://github.com/bcms/utils#readme"
}
